# Telemetry configuration for the EV3 robot controller.
#
# Copy this file to telemetry_config.py and fill in the values before
# deploying to the EV3. The actual telemetry_config.py is gitignored so
# credentials are never committed.

# Full URL of the unified ingress Cloud Function (PEN-227). Superseded
# telemetryIngestion, which used a shared static key instead of a per-device
# token — see cloud/functions/CLAUDE.md.
TELEMETRY_ENDPOINT = "https://<region>-<project>.cloudfunctions.net/unifiedIngress"

# Identifier for this EV3 unit — sent as the X-Device-Id header and included
# in every event's device_id field.
TELEMETRY_DEVICE_ID = "ev3-001"

# Per-device token sent as the X-Device-Token header. Generate/rotate with:
#   bash cloud/functions/setup-device-tokens.sh --device-id ev3-001
TELEMETRY_DEVICE_TOKEN = "your-per-device-token"

# Optional: seconds between liveness heartbeats (PEN-229). Omit this line to
# use HeartbeatSender's own default (telemetry.heartbeat.DEFAULT_HEARTBEAT_INTERVAL).
# TELEMETRY_HEARTBEAT_INTERVAL_S = 30
