# =============================================================================
# WRACK Control Center — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# ─── Authentication (NextAuth.js) ────────────────────────────────────────────
# Required: Random secret for JWT signing. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-32-char-secret

# Users JSON array. Each entry: { id, username, passwordHash, role }
# Roles: admin | operator | viewer
# Generate a bcrypt hash (rounds=10):
#   node -e "const b=require('bcryptjs'); b.hash('your-password',10).then(console.log)"
AUTH_USERS_JSON=[{"id":"1","username":"admin","passwordHash":"$2b$10$examplehashforadminpassword1234","role":"admin"},{"id":"2","username":"operator","passwordHash":"$2b$10$examplehashforoperatorpasswd5678","role":"operator"},{"id":"3","username":"viewer","passwordHash":"$2b$10$examplehashforviewerpassword901","role":"viewer"}]

# ─── Robot API (server-side only — NOT exposed to the browser) ───────────────
# GCP Cloud Function URL for robot control
GCP_FUNCTION_URL=https://europe-central2-wrack-control.cloudfunctions.net/controlRobot

# API Key sent to the Cloud Function (kept server-side via /api/robot proxy)
API_KEY=your-secret-api-key-here

# ─── Optional GCP settings ───────────────────────────────────────────────────
NEXT_PUBLIC_GCP_PROJECT_ID=wrack-control
NEXT_PUBLIC_GCP_REGION=europe-central2

# Robot connection settings (matching iPhone app constants)
NEXT_PUBLIC_ROBOT_HOST=178.183.200.201
NEXT_PUBLIC_ROBOT_PORT=27700
