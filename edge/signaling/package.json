{
  "name": "@wrack/signaling-server",
  "version": "1.0.0",
  "description": "Minimal WebRTC signaling server for Wrack browser video client",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.23",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testTimeout": 10000
  },
  "engines": {
    "node": ">=20"
  }
}
