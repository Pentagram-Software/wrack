# Environment Variables for Mindstorms Cloud Controller
# Copy this file to .env and fill in your actual values

# EV3 Robot Connection
ROBOT_HOST=192.168.1.100
ROBOT_PORT=27700

# API Security (shared by controlRobot and telemetryIngestion)
API_KEY=your-secure-api-key-here

# Generate a secure API key with:
# openssl rand -hex 32

# ---------------------------------------------------------------------------
# Telemetry — BigQuery (optional; used by telemetryIngestion + bigquery-client.js)
# ---------------------------------------------------------------------------
# BIGQUERY_PROJECT_ID — required to enable telemetry.  Omitting it puts
#   bigquery-client.js into opt-out mode: all inserts are silently skipped
#   so robot-control functions are never blocked by telemetry.
BIGQUERY_PROJECT_ID=your-gcp-project-id

# BigQuery dataset name (default: wrack_telemetry)
BIGQUERY_DATASET=wrack_telemetry

# BigQuery table name (default: events)
BIGQUERY_TABLE=events

# ---------------------------------------------------------------------------
# unifiedIngress — device tokens + health-leg routing (PEN-227/PEN-228)
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
DEVICE_TOKENS_SECRET=device-tokens

# healthLegPush's URL, once deployed (see deploy:health-leg). Left unset,
# unifiedIngress fails open on type=health records (logged, dropped).
HEALTH_LEG_FUNCTION_URL=

# ---------------------------------------------------------------------------
# healthLegPush — Grafana Cloud OTLP push (PEN-228)
# ---------------------------------------------------------------------------
# Secret Manager secret holding {otlp_endpoint, instance_id, token} —
# provisioned by cloud/monitoring/setup-grafana-secret.sh (PEN-189). Never
# set the credentials themselves via env var; this only names the secret.
GRAFANA_CREDENTIALS_SECRET=grafana-cloud-push-credentials

# No API key needed locally for healthLegPush's own auth — in production it
# relies on GCP IAM (unifiedIngress's service account is granted the
# Cloud Run/Cloud Functions invoker role on it, deployed --no-allow-
# unauthenticated). Local `npm run start:health-leg` testing therefore
# can't be driven by unifiedIngress's identity-token flow directly; POST to
# it manually with a single event body instead.
