# Environment Variables for Mindstorms Cloud Controller
# Copy this file to .env and fill in your actual values

# EV3 Robot Connection
ROBOT_HOST=192.168.1.100
ROBOT_PORT=27700

# API Security (shared by controlRobot and telemetryIngestion)
API_KEY=your-secure-api-key-here

# Generate a secure API key with:
# openssl rand -hex 32

# BigQuery Telemetry (telemetryIngestion function + bigquery-client.js)
#
# BIGQUERY_PROJECT_ID — required to enable telemetry.  Omitting it puts
#   bigquery-client.js into opt-out mode: all inserts are silently skipped
#   so robot-control functions are never blocked by telemetry.
BIGQUERY_PROJECT_ID=wrack-control
#
# BIGQUERY_DATASET — BigQuery dataset (default: wrack_telemetry)
BIGQUERY_DATASET=wrack_telemetry
#
# BIGQUERY_TABLE — table inside the dataset (default: events)
BIGQUERY_TABLE=events
