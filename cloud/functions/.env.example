# Environment Variables for Mindstorms Cloud Controller
# Copy this file to .env and fill in your actual values

# EV3 Robot Connection
ROBOT_HOST=192.168.1.100
ROBOT_PORT=27700

# API Security
API_KEY=your-secure-api-key-here

# Generate a secure API key with:
# openssl rand -hex 32

# ---------------------------------------------------------------------------
# Telemetry — BigQuery (optional)
# ---------------------------------------------------------------------------
# Set BIGQUERY_PROJECT_ID to enable telemetry ingestion.
# When omitted, telemetry calls are silently no-ops (robot control is unaffected).

# GCP project that owns the BigQuery dataset (required to enable telemetry)
BIGQUERY_PROJECT_ID=your-gcp-project-id

# BigQuery dataset name (default: wrack_telemetry)
BIGQUERY_DATASET=wrack_telemetry

# BigQuery table name (default: events)
BIGQUERY_TABLE=events
