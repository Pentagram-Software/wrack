{
  "name": "mindstorms-cloud-controller",
  "version": "1.0.0",
  "description": "GCP Cloud Functions for controlling Mindstorms robot over IP",
  "main": "index.js",
  "scripts": {
    "start": "functions-framework --target=controlRobot",
    "deploy": "gcloud functions deploy controlRobot --runtime nodejs20 --trigger-http --allow-unauthenticated --region europe-central2 --set-env-vars ROBOT_HOST=${ROBOT_HOST},ROBOT_PORT=${ROBOT_PORT},API_KEY=${API_KEY}",
    "test-robot": "node test-client.js",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "axios": "^1.6.7",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "projects": [
      {
        "displayName": "js",
        "testMatch": [
          "**/*.test.js"
        ],
        "testEnvironment": "node"
      },
      {
        "displayName": "ts",
        "preset": "ts-jest",
        "testMatch": [
          "**/*.test.ts"
        ],
        "testEnvironment": "node",
        "globals": {
          "ts-jest": {
            "tsconfig": "tsconfig.json"
          }
        }
      }
    ]
  },
  "engines": {
    "node": "20"
  }
}
